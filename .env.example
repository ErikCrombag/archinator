# ── GHCR images ──────────────────────────────────────────────────────────────
# GitHub username or org that owns the ghcr.io packages.
# Set this so docker-compose.yml resolves the correct image names.
GHCR_OWNER=your-github-username
# IMAGE_TAG=latest  # pin to a specific SHA tag if needed, e.g. IMAGE_TAG=abc1234

# ── Ollama ────────────────────────────────────────────────────────────────────
# Ollama runs in ~/docker/ollama on the same host (10.1.0.2).
# host.docker.internal resolves to the Docker host via extra_hosts in compose.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.3

# ── Backend ───────────────────────────────────────────────────────────────────
DB_PATH=/app/data/archinator.db
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the browser uses to reach the backend.
# On the server: use the host IP (or public domain if behind Caddy).
VITE_API_URL=http://10.1.0.2:8000
