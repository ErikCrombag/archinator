# ── GHCR images ──────────────────────────────────────────────────────────────
# GitHub username or org that owns the ghcr.io packages.
# Set this so docker-compose.yml resolves the correct image names.
GHCR_OWNER=your-github-username
# IMAGE_TAG=latest  # pin to a specific SHA tag if needed, e.g. IMAGE_TAG=abc1234

# ── Ollama ────────────────────────────────────────────────────────────────────
# Local: OLLAMA_BASE_URL=http://ollama:11434  (no API key needed)
# Cloud: OLLAMA_BASE_URL=https://ollama.com   + OLLAMA_API_KEY=<your key>
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_NUM_CTX=131072
# OLLAMA_API_KEY=         # set for Ollama cloud (https://ollama.com)
EMBED_MODEL=bge-m3

# ── PlantUML ──────────────────────────────────────────────────────────────────
# Path to plantuml.jar for local rendering (ArchiMate stdlib included).
# Falls back to kroki.io if file not found.
# Download: curl -L -o lib/plantuml.jar https://github.com/plantuml/plantuml/releases/latest/download/plantuml.jar
PLANTUML_JAR=lib/plantuml.jar

# ── Backend ───────────────────────────────────────────────────────────────────
DB_PATH=/app/data/archinator.db
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the browser uses to reach the backend.
# On the server: use the host IP (or public domain if behind Caddy).
VITE_API_URL=http://10.1.0.2:8000
