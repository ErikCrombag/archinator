# Ollama server (on AI server host, reachable from Docker container)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.3

# Paths (relative to backend working dir, or absolute)
DB_PATH=/app/data/archinator.db

# Logging
LOG_LEVEL=INFO

# Frontend
VITE_API_URL=http://localhost:8000
